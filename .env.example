# ============================================================
#  .env.example  —  copy this to a file named ".env" locally
#  (Your real ".env" is git-ignored and must NEVER be pushed.)
#  On Vercel, add these same names/values in
#  Settings → Environment Variables (do NOT rely on .env there).
# ============================================================

# ---- Supabase ----
# Replace with YOUR OWN Supabase project values once you create your account.
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-public-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-SECRET-key"     # server only, keep private
VITE_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-public-key"

# ---- Google Sign-in (optional) ----
VITE_GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
VITE_GOOGLE_AUTH_PROXY="https://designarena.ai/auth/google/callback"

# ---- Razorpay ----
# Key ID is public-safe. Key SECRET is server-only — never prefix a secret with VITE_.
VITE_RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxx"
RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxx"
RAZORPAY_KEY_SECRET="your-razorpay-secret"                    # regenerate before real use
RAZORPAY_WEBHOOK_SECRET="choose-any-strong-string"            # must match Razorpay webhook config
